                WRITE (*, *) "       not identical - out of tol.: ", comp_check_status%numouttol 
                WRITE (*, *) "       not identical - within tol.: ", comp_check_status%numintol 
                WRITE (*, *) "" 
            END IF   
        END IF   
    END IF   
      
    dtype_check_status%numTotal = dtype_check_status%numTotal + 1 
    CALL kgen_init_check(comp_check_status, rank=check_status%rank) 
    CALL kv_rosco_types_resparams("resp", comp_check_status, var%resp, kgenref_var%resp) 
    IF (comp_check_status%numTotal == comp_check_status%numIdentical) THEN 
        dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank == 0) THEN 
                WRITE (*, *) trim(adjustl(varname))//"%resp", " is IDENTICAL." 
            END IF   
        END IF   
        check_result = CHECK_IDENTICAL 
    ELSE IF (comp_check_status%numOutTol > 0) THEN 
        dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
        IF (kgen_verboseLevel > 1) THEN 
            IF (check_status%rank == 0) THEN 
                WRITE (*, *) trim(adjustl(varname)), "%resp is NOT IDENTICAL(out of tolerance)." 
            END IF   
        END IF   
        check_result = CHECK_OUT_TOL 
    ELSE IF (comp_check_status%numInTol > 0) THEN 
        dtype_check_status%numInTol = dtype_check_status%numInTol + 1 
        IF (kgen_verboseLevel > 1) THEN 
            IF (check_status%rank == 0) THEN 
                WRITE (*, *) trim(adjustl(varname)), "%resp is NOT IDENTICAL(within tolerance)." 
            END IF   
        END IF   
        check_result = CHECK_IN_TOL 
    END IF   
    IF (check_result == CHECK_IDENTICAL) THEN 
        CONTINUE 
    ELSE IF (check_result == CHECK_OUT_TOL) THEN 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank ==0) THEN 
                WRITE (*, *) "       number of components             : ", comp_check_status%numtotal 
                WRITE (*, *) "       identical                                   : ", comp_check_status%numidentical 
                WRITE (*, *) "       not identical - out of tol.: ", comp_check_status%numouttol 
                WRITE (*, *) "       not identical - within tol.: ", comp_check_status%numintol 
                WRITE (*, *) "" 
            END IF   
        END IF   
    ELSE IF (check_result == CHECK_IN_TOL) THEN 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank ==0) THEN 
                WRITE (*, *) "       number of components             : ", comp_check_status%numtotal 
                WRITE (*, *) "       identical                                   : ", comp_check_status%numidentical 
                WRITE (*, *) "       not identical - out of tol.: ", comp_check_status%numouttol 
                WRITE (*, *) "       not identical - within tol.: ", comp_check_status%numintol 
                WRITE (*, *) "" 
            END IF   
        END IF   
    END IF   
      
    dtype_check_status%numTotal = dtype_check_status%numTotal + 1 
    CALL kgen_init_check(comp_check_status, rank=check_status%rank) 
    CALL kv_rosco_types_rlparams("rlp", comp_check_status, var%rlp, kgenref_var%rlp) 
    IF (comp_check_status%numTotal == comp_check_status%numIdentical) THEN 
        dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank == 0) THEN 
                WRITE (*, *) trim(adjustl(varname))//"%rlp", " is IDENTICAL." 
            END IF   
        END IF   
        check_result = CHECK_IDENTICAL 
    ELSE IF (comp_check_status%numOutTol > 0) THEN 
        dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
        IF (kgen_verboseLevel > 1) THEN 
            IF (check_status%rank == 0) THEN 
                WRITE (*, *) trim(adjustl(varname)), "%rlp is NOT IDENTICAL(out of tolerance)." 
            END IF   
        END IF   
        check_result = CHECK_OUT_TOL 
    ELSE IF (comp_check_status%numInTol > 0) THEN 
        dtype_check_status%numInTol = dtype_check_status%numInTol + 1 
        IF (kgen_verboseLevel > 1) THEN 
            IF (check_status%rank == 0) THEN 
                WRITE (*, *) trim(adjustl(varname)), "%rlp is NOT IDENTICAL(within tolerance)." 
            END IF   
        END IF   
        check_result = CHECK_IN_TOL 
    END IF   
    IF (check_result == CHECK_IDENTICAL) THEN 
        CONTINUE 
    ELSE IF (check_result == CHECK_OUT_TOL) THEN 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank ==0) THEN 
                WRITE (*, *) "       number of components             : ", comp_check_status%numtotal 
                WRITE (*, *) "       identical                                   : ", comp_check_status%numidentical 
                WRITE (*, *) "       not identical - out of tol.: ", comp_check_status%numouttol 
                WRITE (*, *) "       not identical - within tol.: ", comp_check_status%numintol 
                WRITE (*, *) "" 
            END IF   
        END IF   
    ELSE IF (check_result == CHECK_IN_TOL) THEN 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank ==0) THEN 
                WRITE (*, *) "       number of components             : ", comp_check_status%numtotal 
                WRITE (*, *) "       identical                                   : ", comp_check_status%numidentical 
                WRITE (*, *) "       not identical - out of tol.: ", comp_check_status%numouttol 
                WRITE (*, *) "       not identical - within tol.: ", comp_check_status%numintol 
                WRITE (*, *) "" 
            END IF   
        END IF   
    END IF   
      
    IF (dtype_check_status%numTotal == dtype_check_status%numIdentical) THEN 
        check_status%numIdentical = check_status%numIdentical + 1 
    ELSE IF (dtype_check_status%numOutTol > 0) THEN 
        check_status%numOutTol = check_status%numOutTol + 1 
    ELSE IF (dtype_check_status%numInTol > 0) THEN 
        check_status%numInTol = check_status%numInTol + 1 
    END IF   
END SUBROUTINE kv_rosco_types_localvariables 
  
!verify state subroutine for kv_rosco_types_performancedata 
RECURSIVE SUBROUTINE kv_rosco_types_performancedata(varname, check_status, var, kgenref_var) 
    CHARACTER(LEN=*), INTENT(IN) :: varname 
    TYPE(check_t), INTENT(INOUT) :: check_status 
    TYPE(performancedata), INTENT(IN) :: var, kgenref_var 
    TYPE(check_t) :: dtype_check_status, comp_check_status 
    INTEGER :: check_result 
    LOGICAL :: is_print = .FALSE. 
      
    INTEGER :: n_tsr_vec 
    real(KIND=dbki) :: nrmsdiff_tsr_vec, rmsdiff_tsr_vec 
    real(KIND=dbki), ALLOCATABLE :: buf1_tsr_vec(:), buf2_tsr_vec(:) 
    INTEGER :: n_beta_vec 
    real(KIND=dbki) :: nrmsdiff_beta_vec, rmsdiff_beta_vec 
    real(KIND=dbki), ALLOCATABLE :: buf1_beta_vec(:), buf2_beta_vec(:) 
    INTEGER :: n_cp_mat 
    real(KIND=dbki) :: nrmsdiff_cp_mat, rmsdiff_cp_mat 
    real(KIND=dbki), ALLOCATABLE :: buf1_cp_mat(:,:), buf2_cp_mat(:,:) 
    INTEGER :: n_ct_mat 
    real(KIND=dbki) :: nrmsdiff_ct_mat, rmsdiff_ct_mat 
    real(KIND=dbki), ALLOCATABLE :: buf1_ct_mat(:,:), buf2_ct_mat(:,:) 
    INTEGER :: n_cq_mat 
    real(KIND=dbki) :: nrmsdiff_cq_mat, rmsdiff_cq_mat 
    real(KIND=dbki), ALLOCATABLE :: buf1_cq_mat(:,:), buf2_cq_mat(:,:) 
      
    check_status%numTotal = check_status%numTotal + 1 
      
    CALL kgen_init_check(dtype_check_status, rank=check_status%rank) 
    IF (ALLOCATED(var%tsr_vec)) THEN 
        dtype_check_status%numTotal = dtype_check_status%numTotal + 1 
        IF (ALL(var%tsr_vec == kgenref_var%tsr_vec)) THEN 
            dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%tsr_vec is IDENTICAL." 
                END IF   
            END IF   
            check_result = CHECK_IDENTICAL 
        ELSE 
            ALLOCATE (buf1_tsr_vec(SIZE(var%tsr_vec,dim=1))) 
            ALLOCATE (buf2_tsr_vec(SIZE(var%tsr_vec,dim=1))) 
            n_tsr_vec = COUNT(var%tsr_vec /= kgenref_var%tsr_vec) 
            WHERE ( ABS(kgenref_var%tsr_vec) > kgen_minvalue ) 
                buf1_tsr_vec = ((var%tsr_vec-kgenref_var%tsr_vec)/kgenref_var%tsr_vec)**2 
                buf2_tsr_vec = (var%tsr_vec-kgenref_var%tsr_vec)**2 
            ELSEWHERE 
                buf1_tsr_vec = (var%tsr_vec-kgenref_var%tsr_vec)**2 
                buf2_tsr_vec = buf1_tsr_vec 
            END WHERE   
            nrmsdiff_tsr_vec = SQRT(SUM(buf1_tsr_vec)/REAL(n_tsr_vec)) 
            rmsdiff_tsr_vec = SQRT(SUM(buf2_tsr_vec)/REAL(n_tsr_vec)) 
            IF (rmsdiff_tsr_vec > kgen_tolerance) THEN 
                dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
                IF (kgen_verboseLevel > 1) THEN 
                    IF (check_status%rank == 0) THEN 
                        WRITE (*, *) trim(adjustl(varname)), "%tsr_vec is NOT IDENTICAL(out of tolerance)." 
                    END IF   
                END IF   
                check_result = CHECK_OUT_TOL 
            ELSE 
                dtype_check_status%numInTol = dtype_check_status%numInTol + 1 
                IF (kgen_verboseLevel > 1) THEN 
                    IF (check_status%rank == 0) THEN 
                        WRITE (*, *) trim(adjustl(varname)), "%tsr_vec is NOT IDENTICAL(within tolerance)." 
                    END IF   
                END IF   
                check_result = CHECK_IN_TOL 
            END IF   
        END IF   
        IF (check_result == CHECK_IDENTICAL) THEN 
            CONTINUE 
        ELSE IF (check_result == CHECK_OUT_TOL) THEN 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank ==0) THEN 
                    WRITE (*, *) count( var%tsr_vec /= kgenref_var%tsr_vec), " of ", size( var%tsr_vec ), " elements are &
                    &different." 
                    WRITE (*, *) "Average - kernel ", sum(var%tsr_vec)/real(size(var%tsr_vec)) 
                    WRITE (*, *) "Average - reference ", sum(kgenref_var%tsr_vec)/real(size(kgenref_var%tsr_vec)) 
                    WRITE (*, *) "RMS of difference is ", rmsdiff_tsr_vec 
                    WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_tsr_vec 
                    WRITE (*, *) "" 
                END IF   
            END IF   
        ELSE IF (check_result == CHECK_IN_TOL) THEN 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank ==0) THEN 
                    WRITE (*, *) count( var%tsr_vec /= kgenref_var%tsr_vec), " of ", size( var%tsr_vec ), " elements are &
                    &different." 
                    WRITE (*, *) "Average - kernel ", sum(var%tsr_vec)/real(size(var%tsr_vec)) 
                    WRITE (*, *) "Average - reference ", sum(kgenref_var%tsr_vec)/real(size(kgenref_var%tsr_vec)) 
                    WRITE (*, *) "RMS of difference is ", rmsdiff_tsr_vec 
                    WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_tsr_vec 
                    WRITE (*, *) "" 
                END IF   
            END IF   
        END IF   
          
    END IF   
    IF (ALLOCATED(var%beta_vec)) THEN 
        dtype_check_status%numTotal = dtype_check_status%numTotal + 1 
        IF (ALL(var%beta_vec == kgenref_var%beta_vec)) THEN 
            dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%beta_vec is IDENTICAL." 
                END IF   
            END IF   
            check_result = CHECK_IDENTICAL 
        ELSE 
            ALLOCATE (buf1_beta_vec(SIZE(var%beta_vec,dim=1))) 
            ALLOCATE (buf2_beta_vec(SIZE(var%beta_vec,dim=1))) 
            n_beta_vec = COUNT(var%beta_vec /= kgenref_var%beta_vec) 
            WHERE ( ABS(kgenref_var%beta_vec) > kgen_minvalue ) 
                buf1_beta_vec = ((var%beta_vec-kgenref_var%beta_vec)/kgenref_var%beta_vec)**2 
                buf2_beta_vec = (var%beta_vec-kgenref_var%beta_vec)**2 
            ELSEWHERE 
                buf1_beta_vec = (var%beta_vec-kgenref_var%beta_vec)**2 
                buf2_beta_vec = buf1_beta_vec 
            END WHERE   
            nrmsdiff_beta_vec = SQRT(SUM(buf1_beta_vec)/REAL(n_beta_vec)) 
            rmsdiff_beta_vec = SQRT(SUM(buf2_beta_vec)/REAL(n_beta_vec)) 
            IF (rmsdiff_beta_vec > kgen_tolerance) THEN 
                dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
                IF (kgen_verboseLevel > 1) THEN 
                    IF (check_status%rank == 0) THEN 
                        WRITE (*, *) trim(adjustl(varname)), "%beta_vec is NOT IDENTICAL(out of tolerance)." 
                    END IF   
                END IF   
                check_result = CHECK_OUT_TOL 
            ELSE 
                dtype_check_status%numInTol = dtype_check_status%numInTol + 1 
                IF (kgen_verboseLevel > 1) THEN 
                    IF (check_status%rank == 0) THEN 
                        WRITE (*, *) trim(adjustl(varname)), "%beta_vec is NOT IDENTICAL(within tolerance)." 
                    END IF   
                END IF   
                check_result = CHECK_IN_TOL 
            END IF   
        END IF   
        IF (check_result == CHECK_IDENTICAL) THEN 
            CONTINUE 
        ELSE IF (check_result == CHECK_OUT_TOL) THEN 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank ==0) THEN 
                    WRITE (*, *) count( var%beta_vec /= kgenref_var%beta_vec), " of ", size( var%beta_vec ), " elements are &
                    &different." 
                    WRITE (*, *) "Average - kernel ", sum(var%beta_vec)/real(size(var%beta_vec)) 
                    WRITE (*, *) "Average - reference ", sum(kgenref_var%beta_vec)/real(size(kgenref_var%beta_vec)) 
                    WRITE (*, *) "RMS of difference is ", rmsdiff_beta_vec 
                    WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_beta_vec 
                    WRITE (*, *) "" 
                END IF   
            END IF   
        ELSE IF (check_result == CHECK_IN_TOL) THEN 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank ==0) THEN 
                    WRITE (*, *) count( var%beta_vec /= kgenref_var%beta_vec), " of ", size( var%beta_vec ), " elements are &
                    &different." 
                    WRITE (*, *) "Average - kernel ", sum(var%beta_vec)/real(size(var%beta_vec)) 
                    WRITE (*, *) "Average - reference ", sum(kgenref_var%beta_vec)/real(size(kgenref_var%beta_vec)) 
                    WRITE (*, *) "RMS of difference is ", rmsdiff_beta_vec 
                    WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_beta_vec 
                    WRITE (*, *) "" 
                END IF   
            END IF   
        END IF   
          
    END IF   
    IF (ALLOCATED(var%cp_mat)) THEN 
        dtype_check_status%numTotal = dtype_check_status%numTotal + 1 
        IF (ALL(var%cp_mat == kgenref_var%cp_mat)) THEN 
            dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%cp_mat is IDENTICAL." 
                END IF   
            END IF   
            check_result = CHECK_IDENTICAL 
        ELSE 
            ALLOCATE (buf1_cp_mat(SIZE(var%cp_mat,dim=1),SIZE(var%cp_mat,dim=2))) 
            ALLOCATE (buf2_cp_mat(SIZE(var%cp_mat,dim=1),SIZE(var%cp_mat,dim=2))) 
            n_cp_mat = COUNT(var%cp_mat /= kgenref_var%cp_mat) 
            WHERE ( ABS(kgenref_var%cp_mat) > kgen_minvalue ) 
                buf1_cp_mat = ((var%cp_mat-kgenref_var%cp_mat)/kgenref_var%cp_mat)**2 
                buf2_cp_mat = (var%cp_mat-kgenref_var%cp_mat)**2 
            ELSEWHERE 
                buf1_cp_mat = (var%cp_mat-kgenref_var%cp_mat)**2 
                buf2_cp_mat = buf1_cp_mat 
            END WHERE   
            nrmsdiff_cp_mat = SQRT(SUM(buf1_cp_mat)/REAL(n_cp_mat)) 
            rmsdiff_cp_mat = SQRT(SUM(buf2_cp_mat)/REAL(n_cp_mat)) 
            IF (rmsdiff_cp_mat > kgen_tolerance) THEN 
                dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
                IF (kgen_verboseLevel > 1) THEN 
                    IF (check_status%rank == 0) THEN 
                        WRITE (*, *) trim(adjustl(varname)), "%cp_mat is NOT IDENTICAL(out of tolerance)." 
                    END IF   
                END IF   
                check_result = CHECK_OUT_TOL 
            ELSE 
                dtype_check_status%numInTol = dtype_check_status%numInTol + 1 
                IF (kgen_verboseLevel > 1) THEN 
                    IF (check_status%rank == 0) THEN 
                        WRITE (*, *) trim(adjustl(varname)), "%cp_mat is NOT IDENTICAL(within tolerance)." 
                    END IF   
                END IF   
                check_result = CHECK_IN_TOL 
            END IF   
        END IF   
        IF (check_result == CHECK_IDENTICAL) THEN 
            CONTINUE 
        ELSE IF (check_result == CHECK_OUT_TOL) THEN 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank ==0) THEN 
                    WRITE (*, *) count( var%cp_mat /= kgenref_var%cp_mat), " of ", size( var%cp_mat ), " elements are different." 
                    WRITE (*, *) "Average - kernel ", sum(var%cp_mat)/real(size(var%cp_mat)) 
                    WRITE (*, *) "Average - reference ", sum(kgenref_var%cp_mat)/real(size(kgenref_var%cp_mat)) 
                    WRITE (*, *) "RMS of difference is ", rmsdiff_cp_mat 
                    WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_cp_mat 
                    WRITE (*, *) "" 
                END IF   
            END IF   
        ELSE IF (check_result == CHECK_IN_TOL) THEN 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank ==0) THEN 
                    WRITE (*, *) count( var%cp_mat /= kgenref_var%cp_mat), " of ", size( var%cp_mat ), " elements are different." 
                    WRITE (*, *) "Average - kernel ", sum(var%cp_mat)/real(size(var%cp_mat)) 
                    WRITE (*, *) "Average - reference ", sum(kgenref_var%cp_mat)/real(size(kgenref_var%cp_mat)) 
                    WRITE (*, *) "RMS of difference is ", rmsdiff_cp_mat 
                    WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_cp_mat 
                    WRITE (*, *) "" 
                END IF   
            END IF   
        END IF   
          
    END IF   
    IF (ALLOCATED(var%ct_mat)) THEN 
        dtype_check_status%numTotal = dtype_check_status%numTotal + 1 
        IF (ALL(var%ct_mat == kgenref_var%ct_mat)) THEN 
            dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%ct_mat is IDENTICAL." 
                END IF   
            END IF   
            check_result = CHECK_IDENTICAL 
        ELSE 
            ALLOCATE (buf1_ct_mat(SIZE(var%ct_mat,dim=1),SIZE(var%ct_mat,dim=2))) 
            ALLOCATE (buf2_ct_mat(SIZE(var%ct_mat,dim=1),SIZE(var%ct_mat,dim=2))) 
            n_ct_mat = COUNT(var%ct_mat /= kgenref_var%ct_mat) 
            WHERE ( ABS(kgenref_var%ct_mat) > kgen_minvalue ) 
                buf1_ct_mat = ((var%ct_mat-kgenref_var%ct_mat)/kgenref_var%ct_mat)**2 
                buf2_ct_mat = (var%ct_mat-kgenref_var%ct_mat)**2 
            ELSEWHERE 
                buf1_ct_mat = (var%ct_mat-kgenref_var%ct_mat)**2 
