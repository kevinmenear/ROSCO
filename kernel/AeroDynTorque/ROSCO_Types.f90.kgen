        ELSE 
            ALLOCATE (buf1_ind_bldpitch(SIZE(var%ind_bldpitch,dim=1))) 
            ALLOCATE (buf2_ind_bldpitch(SIZE(var%ind_bldpitch,dim=1))) 
            n_ind_bldpitch = COUNT(var%ind_bldpitch /= kgenref_var%ind_bldpitch) 
            WHERE ( ABS(kgenref_var%ind_bldpitch) > kgen_minvalue ) 
                buf1_ind_bldpitch = ((var%ind_bldpitch-kgenref_var%ind_bldpitch)/kgenref_var%ind_bldpitch)**2 
                buf2_ind_bldpitch = (var%ind_bldpitch-kgenref_var%ind_bldpitch)**2 
            ELSEWHERE 
                buf1_ind_bldpitch = (var%ind_bldpitch-kgenref_var%ind_bldpitch)**2 
                buf2_ind_bldpitch = buf1_ind_bldpitch 
            END WHERE   
            nrmsdiff_ind_bldpitch = SQRT(SUM(buf1_ind_bldpitch)/REAL(n_ind_bldpitch)) 
            rmsdiff_ind_bldpitch = SQRT(SUM(buf2_ind_bldpitch)/REAL(n_ind_bldpitch)) 
            IF (rmsdiff_ind_bldpitch > kgen_tolerance) THEN 
                dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
                IF (kgen_verboseLevel > 1) THEN 
                    IF (check_status%rank == 0) THEN 
