            END WHERE   
            nrmsdiff_ct_mat = SQRT(SUM(buf1_ct_mat)/REAL(n_ct_mat)) 
            rmsdiff_ct_mat = SQRT(SUM(buf2_ct_mat)/REAL(n_ct_mat)) 
            IF (rmsdiff_ct_mat > kgen_tolerance) THEN 
                dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
