            n_f_flpcornerfreq = COUNT(var%f_flpcornerfreq /= kgenref_var%f_flpcornerfreq) 
            WHERE ( ABS(kgenref_var%f_flpcornerfreq) > kgen_minvalue ) 
                buf1_f_flpcornerfreq = ((var%f_flpcornerfreq-kgenref_var%f_flpcornerfreq)/kgenref_var%f_flpcornerfreq)**2 
