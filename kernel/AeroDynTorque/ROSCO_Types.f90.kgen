    IF (ALL(var%lastsignal == kgenref_var%lastsignal)) THEN 
        dtype_check_status%numIdentical = dtype_check_status%numIdentical + 1 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank == 0) THEN 
                WRITE (*, *) trim(adjustl(varname)), "%lastsignal is IDENTICAL." 
            END IF   
        END IF   
        check_result = CHECK_IDENTICAL 
    ELSE 
        ALLOCATE (buf1_lastsignal(SIZE(var%lastsignal,dim=1))) 
        ALLOCATE (buf2_lastsignal(SIZE(var%lastsignal,dim=1))) 
        n_lastsignal = COUNT(var%lastsignal /= kgenref_var%lastsignal) 
        WHERE ( ABS(kgenref_var%lastsignal) > kgen_minvalue ) 
            buf1_lastsignal = ((var%lastsignal-kgenref_var%lastsignal)/kgenref_var%lastsignal)**2 
            buf2_lastsignal = (var%lastsignal-kgenref_var%lastsignal)**2 
        ELSEWHERE 
            buf1_lastsignal = (var%lastsignal-kgenref_var%lastsignal)**2 
            buf2_lastsignal = buf1_lastsignal 
        END WHERE   
        nrmsdiff_lastsignal = SQRT(SUM(buf1_lastsignal)/REAL(n_lastsignal)) 
        rmsdiff_lastsignal = SQRT(SUM(buf2_lastsignal)/REAL(n_lastsignal)) 
        IF (rmsdiff_lastsignal > kgen_tolerance) THEN 
            dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
            IF (kgen_verboseLevel > 1) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%lastsignal is NOT IDENTICAL(out of tolerance)." 
                END IF   
            END IF   
            check_result = CHECK_OUT_TOL 
        ELSE 
            dtype_check_status%numInTol = dtype_check_status%numInTol + 1 
            IF (kgen_verboseLevel > 1) THEN 
                IF (check_status%rank == 0) THEN 
                    WRITE (*, *) trim(adjustl(varname)), "%lastsignal is NOT IDENTICAL(within tolerance)." 
                END IF   
            END IF   
            check_result = CHECK_IN_TOL 
        END IF   
    END IF   
    IF (check_result == CHECK_IDENTICAL) THEN 
        CONTINUE 
    ELSE IF (check_result == CHECK_OUT_TOL) THEN 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank ==0) THEN 
                WRITE (*, *) count( var%lastsignal /= kgenref_var%lastsignal), " of ", size( var%lastsignal ), " elements are &
                &different." 
                WRITE (*, *) "Average - kernel ", sum(var%lastsignal)/real(size(var%lastsignal)) 
                WRITE (*, *) "Average - reference ", sum(kgenref_var%lastsignal)/real(size(kgenref_var%lastsignal)) 
                WRITE (*, *) "RMS of difference is ", rmsdiff_lastsignal 
                WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_lastsignal 
                WRITE (*, *) "" 
            END IF   
        END IF   
    ELSE IF (check_result == CHECK_IN_TOL) THEN 
        IF (kgen_verboseLevel > 2) THEN 
            IF (check_status%rank ==0) THEN 
                WRITE (*, *) count( var%lastsignal /= kgenref_var%lastsignal), " of ", size( var%lastsignal ), " elements are &
                &different." 
                WRITE (*, *) "Average - kernel ", sum(var%lastsignal)/real(size(var%lastsignal)) 
                WRITE (*, *) "Average - reference ", sum(kgenref_var%lastsignal)/real(size(kgenref_var%lastsignal)) 
                WRITE (*, *) "RMS of difference is ", rmsdiff_lastsignal 
                WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_lastsignal 
                WRITE (*, *) "" 
            END IF   
        END IF   
    END IF   
      
    IF (dtype_check_status%numTotal == dtype_check_status%numIdentical) THEN 
        check_status%numIdentical = check_status%numIdentical + 1 
    ELSE IF (dtype_check_status%numOutTol > 0) THEN 
        check_status%numOutTol = check_status%numOutTol + 1 
    ELSE IF (dtype_check_status%numInTol > 0) THEN 
        check_status%numInTol = check_status%numInTol + 1 
    END IF   
