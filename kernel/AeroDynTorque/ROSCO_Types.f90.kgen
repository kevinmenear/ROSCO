                buf2_cq_mat = (var%cq_mat-kgenref_var%cq_mat)**2 
            ELSEWHERE 
                buf1_cq_mat = (var%cq_mat-kgenref_var%cq_mat)**2 
                buf2_cq_mat = buf1_cq_mat 
            END WHERE   
