        ALLOCATE (buf2_ipc_pitcomf(SIZE(var%ipc_pitcomf,dim=1))) 
        n_ipc_pitcomf = COUNT(var%ipc_pitcomf /= kgenref_var%ipc_pitcomf) 
        WHERE ( ABS(kgenref_var%ipc_pitcomf) > kgen_minvalue ) 
            buf1_ipc_pitcomf = ((var%ipc_pitcomf-kgenref_var%ipc_pitcomf)/kgenref_var%ipc_pitcomf)**2 
            buf2_ipc_pitcomf = (var%ipc_pitcomf-kgenref_var%ipc_pitcomf)**2 
        ELSEWHERE 
            buf1_ipc_pitcomf = (var%ipc_pitcomf-kgenref_var%ipc_pitcomf)**2 
            buf2_ipc_pitcomf = buf1_ipc_pitcomf 
        END WHERE   
        nrmsdiff_ipc_pitcomf = SQRT(SUM(buf1_ipc_pitcomf)/REAL(n_ipc_pitcomf)) 
        rmsdiff_ipc_pitcomf = SQRT(SUM(buf2_ipc_pitcomf)/REAL(n_ipc_pitcomf)) 
        IF (rmsdiff_ipc_pitcomf > kgen_tolerance) THEN 
            dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
            IF (kgen_verboseLevel > 1) THEN 
