                    END IF   
                END IF   
                check_result = CHECK_IN_TOL 
            END IF   
        END IF   
        IF (check_result == CHECK_IDENTICAL) THEN 
            CONTINUE 
        ELSE IF (check_result == CHECK_OUT_TOL) THEN 
            IF (kgen_verboseLevel > 2) THEN 
                IF (check_status%rank ==0) THEN 
                    WRITE (*, *) count( var%ct_mat /= kgenref_var%ct_mat), " of ", size( var%ct_mat ), " elements are different." 
                    WRITE (*, *) "Average - kernel ", sum(var%ct_mat)/real(size(var%ct_mat)) 
                    WRITE (*, *) "Average - reference ", sum(kgenref_var%ct_mat)/real(size(kgenref_var%ct_mat)) 
                    WRITE (*, *) "RMS of difference is ", rmsdiff_ct_mat 
                    WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_ct_mat 
                    WRITE (*, *) "" 
