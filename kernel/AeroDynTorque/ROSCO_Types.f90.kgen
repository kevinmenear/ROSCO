        nrmsdiff_zmq_pitoffset = SQRT(SUM(buf1_zmq_pitoffset)/REAL(n_zmq_pitoffset)) 
        rmsdiff_zmq_pitoffset = SQRT(SUM(buf2_zmq_pitoffset)/REAL(n_zmq_pitoffset)) 
        IF (rmsdiff_zmq_pitoffset > kgen_tolerance) THEN 
