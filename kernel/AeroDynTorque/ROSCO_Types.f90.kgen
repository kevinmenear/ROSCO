                    WRITE (*, *) "RMS of difference is ", rmsdiff_ind_bldpitch 
                    WRITE (*, *) "Normalized RMS of difference is ", nrmsdiff_ind_bldpitch 
                    WRITE (*, *) "" 
                END IF   
            END IF   
        ELSE IF (check_result == CHECK_IN_TOL) THEN 
