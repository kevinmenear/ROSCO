        ALLOCATE (buf1_fa_pitcom(SIZE(var%fa_pitcom,dim=1))) 
        ALLOCATE (buf2_fa_pitcom(SIZE(var%fa_pitcom,dim=1))) 
        n_fa_pitcom = COUNT(var%fa_pitcom /= kgenref_var%fa_pitcom) 
        WHERE ( ABS(kgenref_var%fa_pitcom) > kgen_minvalue ) 
            buf1_fa_pitcom = ((var%fa_pitcom-kgenref_var%fa_pitcom)/kgenref_var%fa_pitcom)**2 
            buf2_fa_pitcom = (var%fa_pitcom-kgenref_var%fa_pitcom)**2 
        ELSEWHERE 
            buf1_fa_pitcom = (var%fa_pitcom-kgenref_var%fa_pitcom)**2 
            buf2_fa_pitcom = buf1_fa_pitcom 
        END WHERE   
        nrmsdiff_fa_pitcom = SQRT(SUM(buf1_fa_pitcom)/REAL(n_fa_pitcom)) 
        rmsdiff_fa_pitcom = SQRT(SUM(buf2_fa_pitcom)/REAL(n_fa_pitcom)) 
        IF (rmsdiff_fa_pitcom > kgen_tolerance) THEN 
            dtype_check_status%numOutTol = dtype_check_status%numOutTol + 1 
            IF (kgen_verboseLevel > 1) THEN 
                IF (check_status%rank == 0) THEN 
