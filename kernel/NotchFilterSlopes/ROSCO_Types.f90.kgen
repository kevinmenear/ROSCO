        n_zmq_pitoffset = COUNT(var%zmq_pitoffset /= kgenref_var%zmq_pitoffset) 
        WHERE ( ABS(kgenref_var%zmq_pitoffset) > kgen_minvalue ) 
            buf1_zmq_pitoffset = ((var%zmq_pitoffset-kgenref_var%zmq_pitoffset)/kgenref_var%zmq_pitoffset)**2 
            buf2_zmq_pitoffset = (var%zmq_pitoffset-kgenref_var%zmq_pitoffset)**2 
