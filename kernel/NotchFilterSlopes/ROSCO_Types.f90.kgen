!read state subroutine for kr_rosco_types_we 
RECURSIVE SUBROUTINE kr_rosco_types_we(var, kgen_unit, printname, printvar) 
    TYPE(we), INTENT(INOUT) :: var 
    INTEGER, INTENT(IN) :: kgen_unit 
    CHARACTER(LEN=*), INTENT(IN) :: printname 
    LOGICAL, INTENT(IN), OPTIONAL :: printvar 
    LOGICAL :: kgen_istrue 
    REAL(KIND=8) :: kgen_array_sum 
      
    READ (UNIT = kgen_unit) var%om_r 
    IF (PRESENT( printvar ) .AND. printvar) THEN 
        WRITE (*, *) "KGEN DEBUG: " // printname // "%om_r = ", var%om_r 
    END IF   
      
    READ (UNIT = kgen_unit) var%v_t 
    IF (PRESENT( printvar ) .AND. printvar) THEN 
        WRITE (*, *) "KGEN DEBUG: " // printname // "%v_t = ", var%v_t 
    END IF   
      
    READ (UNIT = kgen_unit) var%v_m 
    IF (PRESENT( printvar ) .AND. printvar) THEN 
        WRITE (*, *) "KGEN DEBUG: " // printname // "%v_m = ", var%v_m 
    END IF   
      
    READ (UNIT = kgen_unit) var%v_h 
    IF (PRESENT( printvar ) .AND. printvar) THEN 
        WRITE (*, *) "KGEN DEBUG: " // printname // "%v_h = ", var%v_h 
    END IF   
      
    READ (UNIT = kgen_unit) kgen_istrue 
    IF (kgen_istrue) THEN 
