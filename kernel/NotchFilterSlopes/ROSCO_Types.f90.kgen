                WRITE (*, *) "Average - kernel ", sum(var%ipc_pitcomf)/real(size(var%ipc_pitcomf)) 
                WRITE (*, *) "Average - reference ", sum(kgenref_var%ipc_pitcomf)/real(size(kgenref_var%ipc_pitcomf)) 
                WRITE (*, *) "RMS of difference is ", rmsdiff_ipc_pitcomf 
